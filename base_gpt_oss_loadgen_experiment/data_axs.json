{
    "_parent_entries": [ [ "^", "byname", "base_loadgen_experiment" ] ],
    "accuracy_log_path": ["^^", "get_path", [[ "offline", "accuracy", "mlperf_log_accuracy.json" ]] ],
    "output_accuracy_path": ["^^", "get_path",  [[ "offline", "accuracy", "accuracy_results.json" ]] ],
    "mlperf_inference_git_entry": [ "^", "byquery", "git_repo,repo_name=mlperf_inference_git" ],

    "abs_script_path": [ "^^", "execute", [[
        [ "get", "mlperf_inference_git_entry" ],
        [ "get_path_of", "gpt_oss_accuracy_script"  ]
    ]] ],

    "model_entry": [ "^", "byquery", "downloaded,openai_model,model_name=gpt-oss-120b" ],
    "model_path": [ "^^", "execute", [[
        [ "get", "model_entry" ],
        [ "get_path" ]
    ]] ],
    "dataset_name": "mlperf-dataset-for-gpt-oss-120b",
    "dataset_entry": [ "^", "byquery", "downloaded,dataset_name=mlperf-dataset-for-gpt-oss-120b" ],
    "dataset_path": [ "^^", "execute", [[
        [ "get", "dataset_entry" ],
        [ "get_path", [ [ "gpt-oss_data", "acc","acc_eval_ref.parquet"] ] ]
    ]]],

    "extract_accuracy_report": [ "^^", "execute", [[
    [ "get_kernel" ],
    [ "byname", "python_script" ],
    [ "run", [], {
        "desired_python_version": "3.12",
        "abs_script_path": ["^^", "get", "abs_script_path"],
        "script_extra_params": [ "^^", "substitute", "--mlperf-log \"#{accuracy_log_path}#\" --reference-data \"#{dataset_path}#\" --tokenizer \"#{model_path}#\" --output-file \"#{output_accuracy_path}#\"" ],
        "capture_output": true
    } ],
    0,
    [ "func", [ "ufun.rematch", "\\'exact_match\\'\\s*:\\s*([0-9.]+)" ] ]
    ]], {} ],

    "accuracy": [ "^^", "execute", [[
        [ "get", "accuracy_report" ],
        0,
        [ "func", "eval" ]
    ]], {} ],
    "accuracy_full_report": [ "^^", "execute", [[
	    [ "get_path",  [[ "offline", "accuracy", "accuracy_results.json" ]] ],
	    0,
	    [ "func", "ufun.load_json"]
	     ]] ]
	    


}
